{
  "cli": {
    "version": ">= 20.5.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "parent"
      }
    },
    "driver": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "APP_VARIANT": "driver"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "parent"
      }
    },
    "production:driver": {
      "android": {
        "buildType": "app-bundle"
      },
      "env": {
        "APP_VARIANT": "driver"
      }
    }
  }
}

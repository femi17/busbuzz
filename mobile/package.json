{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.3",
    "@react-navigation/native": "^7.3.4",
    "@react-navigation/native-stack": "^7.17.6",
    "@rnmapbox/maps": "^10.3.2",
    "@supabase/supabase-js": "^2.108.2",
    "expo": "~56.0.15",
    "expo-constants": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-linking": "~56.0.15",
    "expo-location": "~56.0.20",
    "expo-notifications": "~56.0.20",
    "expo-splash-screen": "~56.0.12",
    "expo-status-bar": "~56.0.4",
    "expo-task-manager": "~56.0.21",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-url-polyfill": "^3.0.0",
    "zod": "^3.23.8 || ^4.0.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "start:driver": "APP_VARIANT=driver expo start",
    "start:parent": "expo start",
    "build:parent:apk": "eas build --platform android --profile preview",
    "build:driver:apk": "eas build --platform android --profile driver",
    "build:parent:prod": "eas build --platform android --profile production",
    "build:driver:prod": "eas build --platform android --profile production:driver",
    "prebuild:parent": "expo prebuild --clean -p android",
    "prebuild:driver": "APP_VARIANT=driver expo prebuild --clean -p android",
    "build:parent:apk:local": "npm run prebuild:parent && cd android && ./gradlew assembleDebug",
    "build:driver:apk:local": "npm run prebuild:driver && cd android && ./gradlew assembleDebug"
  },
  "private": true
}

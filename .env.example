# ============================================================
# web/.env.local
# ============================================================
# From Supabase Dashboard -> busbuzz-dev project -> Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://nmgvnoudmxrzqthnfxkk.supabase.co
# From Supabase Dashboard -> Settings -> API -> anon public key (safe to expose to client; protected by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5tZ3Zub3VkbXhyenF0aG5meGtrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3MjU4NjgsImV4cCI6MjA5ODMwMTg2OH0.rUL3_PXXbFGtAVdW-Zhw0pjvmFCaP_YZ3AljWganBaY
# From Google Cloud Console -> APIs & Services -> Credentials (restrict to Maps JavaScript API + Places API, HTTP referrer restricted to your domain)
NEXT_PUBLIC_GOOGLEMAP_TOKEN=
# From Supabase Dashboard -> Settings -> API -> service_role key.
# NEVER commit a real value here — this file is tracked in git (see .gitignore's
# "!.env.example" exception). Keep this blank; put the real key only in your
# local, gitignored web/.env.local.
SUPABASE_SERVICE_ROLE_KEY=

# ============================================================
# mobile/.env
# ============================================================
EXPO_PUBLIC_SUPABASE_URL=https://nmgvnoudmxrzqthnfxkk.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5tZ3Zub3VkbXhyenF0aG5meGtrIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODI3MjU4NjgsImV4cCI6MjA5ODMwMTg2OH0.rUL3_PXXbFGtAVdW-Zhw0pjvmFCaP_YZ3AljWganBaY
# GPS broadcast interval in milliseconds (10 seconds, per CLAUDE.md)
EXPO_PUBLIC_GPS_INTERVAL_MS=10000
# Metres from a stop to trigger an "approaching" push notification, per CLAUDE.md
EXPO_PUBLIC_GEOFENCE_RADIUS_M=300
# From mapbox.com -> Account -> Tokens. Public token (starts "pk."), safe to
# ship in the client bundle — used at runtime to render the map.
EXPO_PUBLIC_MAPBOX_TOKEN=
# From mapbox.com -> Account -> Tokens -> Create a token -> enable "Downloads:Read" scope.
# A SEPARATE secret token (starts "sk."), never the same as the public one above.
# Build-time only (do not prefix with EXPO_PUBLIC_ — it must not end up in the client
# bundle). Required to authenticate Mapbox's private Maven/CocoaPods registry when EAS
# builds the native @rnmapbox/maps SDK; the build fails with a 401 without it.
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=

# ============================================================
# supabase/functions/.env (set via Supabase Dashboard -> Edge Functions -> Secrets)
# ============================================================
# Auto-injected by Supabase at runtime — do not set manually, listed for reference only
SUPABASE_URL=
# Auto-injected by Supabase at runtime — do not set manually, listed for reference only
SUPABASE_SERVICE_ROLE_KEY=
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send
GOOGLE_MAPS_API_KEY=              # Server-side Google Geocoding API key (school address -> coordinates). Use a separate, IP-restricted key from the client NEXT_PUBLIC_GOOGLEMAP_TOKEN.
# Most On-Time Student award email (compute-ontime-award function). Without RESEND_API_KEY the
# award is still computed + saved, it just won't email. This is a separate secret from the
# Resend SMTP wiring used by Supabase Auth — the function calls the Resend HTTP API directly.
RESEND_API_KEY=                   # From resend.com -> API Keys
AWARD_FROM_EMAIL=                 # e.g. "BusBuzz Awards <awards@yourdomain.com>" — must be a Resend-verified sender/domain. Defaults to awards@busbuzz.app.
AWARD_EMAIL_TO=                   # Recipient of the award summary. Defaults to scrpoll07@gmail.com.

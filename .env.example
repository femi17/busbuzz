# From Supabase Dashboard -> Settings -> API -> service_role key.
# NEVER commit a real value here — this file is tracked in git (see .gitignore's
# "!.env.example" exception). Keep this blank; put the real key only in your
# local, gitignored web/.env.local.
SUPABASE_SERVICE_ROLE_KEY=

